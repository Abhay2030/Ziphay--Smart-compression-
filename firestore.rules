rules_version = '2';

// ══════════════════════════════════════════════
//  Ziphay — Firestore Security Rules (Hardened)
//  Users can ONLY access their own data.
//  Profile writes restricted to safe fields.
//  Plan field BLOCKED from client writes (H8/H9).
// ══════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User history collection ──
    // Path: /users/{userId}/history/{recordId}
    match /users/{userId}/history/{recordId} {
      // Allow read ONLY if the authenticated user's UID matches
      allow read: if request.auth != null && request.auth.uid == userId;

      // Allow create with validated fields
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasOnly([
                         'filename', 'outputName', 'mode', 'goal', 'level',
                         'format', 'origSize', 'newSize', 'savedPct',
                         'scale', 'createdAt'
                       ])
                    // Validate types
                    && request.resource.data.filename is string
                    && request.resource.data.filename.size() <= 500
                    && request.resource.data.mode is string
                    && request.resource.data.mode in ['compress', 'upscale', 'denoise', 'bgremove']
                    && request.resource.data.origSize is int
                    && request.resource.data.newSize is int;

      // Allow delete — user can remove their own history
      allow delete: if request.auth != null && request.auth.uid == userId;

      // Disallow update on history records (they are immutable logs)
      allow update: if false;
    }

    // ── User profile ──
    // SECURITY: Client writes are restricted to safe fields ONLY.
    // The 'plan' field can NOT be set by the client — only by a
    // Cloud Function after payment verification (H8/H9 fix).
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;

      // Allow create with restricted fields
      allow create: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.keys().hasOnly([
                         'displayName', 'photoURL', 'preferences', 'createdAt', 'plan'
                       ])
                    // On creation, plan can be 'free', 'pro', or absent (all features unlocked)
                    && (!('plan' in request.resource.data) || request.resource.data.plan in ['free', 'pro']);

      // Allow update — only safe fields, NEVER plan/role/admin
      allow update: if request.auth != null
                    && request.auth.uid == userId
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['displayName', 'photoURL', 'preferences'])
                    // Block any attempt to modify plan, role, admin, etc.
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny(['plan', 'role', 'admin', 'isAdmin', 'isPro']);
    }

    // ── Deny everything else by default ──
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
