# ══════════════════════════════════════════════════
# Ziphay Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# ══════════════════════════════════════════════════

# ── Environment ──
# Set to "production" for production deployment
ENVIRONMENT=development

# ── File Processing ──
# Maximum upload size in MB (50 for free tier, 2048 for pro)
MAX_UPLOAD_SIZE_MB=50

# Storage directory for temporary file processing
STORAGE_DIR=files_vault

# Auto-delete delay in seconds (3600 = 1 hour)
AUTO_DELETE_DELAY_SECONDS=3600

# ── Rate Limiting ──
# Max requests per minute per IP for the compress endpoint
RATE_LIMIT_COMPRESS=10

# Max requests per minute per IP for the download endpoint
RATE_LIMIT_DOWNLOAD=30

# Max requests per minute per IP for the stats endpoint
RATE_LIMIT_STATS=20

# ── CORS ──
# Comma-separated list of allowed origins
CORS_ORIGINS=https://ziphay-smart-compression.vercel.app,https://ziphay.web.app,https://ziphay.firebaseapp.com

# ── Firebase (for token verification) ──
# Your Firebase project ID
FIREBASE_PROJECT_ID=ziphay

# ── Logging ──
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
